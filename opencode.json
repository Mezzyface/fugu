{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "sakana-ai": {
      "name": "Sakana AI",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://api.sakana.ai/v1",
        "timeout": 7200000,
        "chunkTimeout": 7200000
      },
      "models": {
        "fugu": {
          "name": "Fugu",
          "family": "Sakana Fugu",
          "attachment": true,
          "reasoning": true,
          "tool_call": true,
          "limit": { "context": 1000000, "output": 10000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] },
          "status": "active",
          "variants": {
            "low": { "disabled": true },
            "medium": { "disabled": true },
            "high": { "reasoningEffort": "high" }
          }
        },
        "fugu-ultra": {
          "name": "Fugu Ultra",
          "family": "Sakana Fugu",
          "attachment": true,
          "reasoning": true,
          "tool_call": true,
          "cost": {
            "input": 5,
            "output": 30,
            "cache_read": 0.5,
            "context_over_200k": { "input": 10, "output": 45, "cache_read": 1 }
          },
          "limit": { "context": 1000000, "output": 10000 },
          "modalities": { "input": ["text", "image"], "output": ["text"] },
          "status": "active",
          "variants": {
            "low": { "disabled": true },
            "medium": { "disabled": true },
            "high": { "reasoningEffort": "high" }
          }
        }
      }
    }
  }
}
