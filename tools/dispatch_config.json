    "in_progress": "In progress",
    "in_review": "In review",
    "needs_human": "Needs Human",
    "done": "Done"
  },
  "labels": {
    "agent": "agent:claude",
    "human": "human",
    "deliverable": "deliverable",
    "qa": "qa",
    "ui": "ui",
    "rework": "rework"
  },
  "worktree_dir": ".dispatch-wt",
  "runs_dir": ".dispatch-runs"
}
